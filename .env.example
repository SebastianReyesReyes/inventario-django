# Django
# IMPORTANTE: No usar valores placeholder como 'your-secret-key-here' o 'django-insecure-'.
# El sistema falla al arrancar si detecta una SECRET_KEY insegura.
DJANGO_SECRET_KEY=cambia-por-una-clave-segura-de-al-menos-50-caracteres
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Ruta opcional para la base de datos SQLite (por defecto: db.sqlite3 en raíz).
# Útil para Docker o entornos donde el volumen de datos debe estar separado.
# DB_PATH=/data/db.sqlite3
DATABASE_URL=sqlite:///db.sqlite3

# MCP Servers (Google SecOps example)
# MCP_SERVER_URL=https://chronicle.us.rep.googleapis.com/mcp
# MCP_AUTH_TOKEN=your-auth-token
# MCP_PROJECT_ID=your-project-id
